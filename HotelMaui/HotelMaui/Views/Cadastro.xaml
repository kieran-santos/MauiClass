<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelMaui.Views.Cadastro"
             Title="Cadastro">

    <VerticalStackLayout>
        <Label Text="Cadastre-se"/>
        <Border Margin="10"
            BackgroundColor="Black">
            <VerticalStackLayout Margin="10" Spacing="10">  
                <Border Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Nome"/>
                        <Label Text="{Binding Value}"
                           BindingContext="{x:Reference txt_nome}"/>
                        <Entry x:Name="txt_nome"
                           Placeholder="Digite seu nome"/>

                        <Label Text="E-mail"/>
                        <Label Text="{Binding Value}"
                           BindingContext="{x:Reference txt_email}"/>
                        <Entry x:Name="txt_email"
                           Keyboard="Email" 
                           Placeholder="Digite seu e-mail"/>

                        <Label Text="Senha"/>
                        <Label Text="{Binding Value}"
                           BindingContext="{x:Reference txt_senha}"/>
                        <Entry x:Name="txt_senha"
                           IsPassword="True"
                           Placeholder="Digite sua senha"/>
                        <Button Text="Salvar" Clicked="Button_Clicked"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>